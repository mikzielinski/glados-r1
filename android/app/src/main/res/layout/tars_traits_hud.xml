<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tarsTraitsHudRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal|top"
    android:layout_marginHorizontal="14dp"
    android:layout_marginTop="34dp"
    android:background="@drawable/bg_transcript_oko"
    android:orientation="vertical"
    android:padding="10dp"
    android:visibility="gone">

    <TextView
        android:id="@+id/tarsHudTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:gravity="center"
        android:letterSpacing="0.12"
        android:text="@string/tars_hud_title"
        android:textAllCaps="true"
        android:textColor="@color/tars_500"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/tarsHudChanged"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:textColor="@color/clinical_100"
        android:textSize="10sp"
        tools:text="Humor → 60%" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tarsHudHonestyLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/clinical_300"
            android:textSize="9sp"
            tools:text="Szczerość 90" />

        <ProgressBar
            android:id="@+id/tarsHudHonestyBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="2dp"
            android:max="100"
            android:progressTint="@color/tars_500"
            tools:progress="90" />

        <TextView
            android:id="@+id/tarsHudHumorLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:textColor="@color/clinical_300"
            android:textSize="9sp"
            tools:text="Humor 75" />

        <ProgressBar
            android:id="@+id/tarsHudHumorBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="2dp"
            android:max="100"
            android:progressTint="@color/status_info"
            tools:progress="75" />

        <TextView
            android:id="@+id/tarsHudSarcasmLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:textColor="@color/clinical_300"
            android:textSize="9sp"
            tools:text="Sarkazm 35" />

        <ProgressBar
            android:id="@+id/tarsHudSarcasmBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="2dp"
            android:max="100"
            android:progressTint="@color/amber_500"
            tools:progress="35" />
    </LinearLayout>
</LinearLayout>
