<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:text="@string/settings_skin_title"
            android:textAllCaps="true"
            android:textColor="@color/clinical_300"
            android:textSize="10sp" />

        <Spinner
            android:id="@+id/skinSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_transcript"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:text="@string/settings_lang_title"
            android:textAllCaps="true"
            android:textColor="@color/clinical_300"
            android:textSize="10sp" />

        <Spinner
            android:id="@+id/langSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_transcript"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tarsTraitsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:text="@string/settings_tars_traits_title"
            android:textAllCaps="true"
            android:textColor="@color/clinical_300"
            android:textSize="10sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/tarsTraitsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:text="@string/settings_tars_honesty_name"
                    android:textColor="@color/clinical_300"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tarsHonestyValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/clinical_50"
                    android:textSize="11sp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/tarsHonestySeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:text="@string/settings_tars_humor_name"
                    android:textColor="@color/clinical_300"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tarsHumorValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/clinical_50"
                    android:textSize="11sp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/tarsHumorSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:text="@string/settings_tars_sarcasm_name"
                    android:textColor="@color/clinical_300"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tarsSarcasmValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/clinical_50"
                    android:textSize="11sp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/tarsSarcasmSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />
        </LinearLayout>

        <Button
            android:id="@+id/newSessionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:text="@string/settings_new_session"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:text="@string/settings_memory_title"
            android:textAllCaps="true"
            android:textColor="@color/clinical_300"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/memoryCountLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="@string/settings_memory_count"
            android:textColor="@color/clinical_50"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/memoryNoteInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_transcript"
            android:fontFamily="monospace"
            android:gravity="top"
            android:hint="@string/settings_memory_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:padding="10dp"
            android:textColor="@color/clinical_50"
            android:textColorHint="@color/clinical_700"
            android:textSize="11sp" />

        <Button
            android:id="@+id/memoryLearnButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="@string/settings_memory_learn"
            android:textAllCaps="true" />

        <Button
            android:id="@+id/memoryUploadButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="@string/settings_memory_upload"
            android:textAllCaps="true" />

        <Button
            android:id="@+id/memoryForceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="@string/settings_memory_force"
            android:textAllCaps="true" />

        <Button
            android:id="@+id/memoryClearButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="@string/settings_memory_clear"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:text="@string/settings_backend_title"
            android:textAllCaps="true"
            android:textColor="@color/clinical_300"
            android:textSize="10sp" />

        <EditText
            android:id="@+id/backendUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_transcript"
            android:fontFamily="monospace"
            android:gravity="top"
            android:hint="@string/settings_backend_hint"
            android:inputType="textMultiLine|textUri"
            android:minLines="2"
            android:padding="10dp"
            android:textColor="@color/clinical_50"
            android:textColorHint="@color/clinical_700"
            android:textSize="11sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:text="@string/settings_backend_help"
            android:textColor="@color/clinical_500"
            android:textSize="9sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:text="@string/settings_side_button_title"
            android:textAllCaps="true"
            android:textColor="@color/clinical_300"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/deviceAdminStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:textColor="@color/clinical_50"
            android:textSize="11sp" />

        <Button
            android:id="@+id/deviceAdminButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="@string/settings_device_admin_enable"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="3dp"
            android:text="@string/settings_side_button_help"
            android:textColor="@color/clinical_500"
            android:textSize="9sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp"
            android:text="@string/settings_controls_help"
            android:textColor="@color/clinical_500"
            android:textSize="10sp" />
    </LinearLayout>
</ScrollView>
