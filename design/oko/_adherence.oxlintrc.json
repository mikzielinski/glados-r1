{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/conversation/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/r1-agent/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|loading|icon|iconRight|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, loading, icon, iconRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|actions|padded|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, label, actions, padded."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|icon|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, hint, error, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|shape|label|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, shape, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:square|circle)$/]",
        "message": "<IconButton> shape must be one of 'square' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Lens'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|size|amplitude|label|key|ref|className|style|children)$/]",
        "message": "<Lens> doesn't accept that prop. Declared props: state, size, amplitude, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:author|name|time|typing|key|ref|className|style|children)$/]",
        "message": "<MessageBubble> doesn't accept that prop. Declared props: author, name, time, typing."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageBubble'] > JSXAttribute[name.name='author'] > Literal[value!=/^(?:oko|user)$/]",
        "message": "<MessageBubble> author must be one of 'oko' | 'user'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|solid|pulse|dot|key|ref|className|style|children)$/]",
        "message": "<StatusChip> doesn't accept that prop. Declared props: tone, solid, pulse, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='SystemBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|tone|time|battery|signal|right|key|ref|className|style|children)$/]",
        "message": "<SystemBar> doesn't accept that prop. Declared props: state, tone, time, battery, signal, right."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|sublabel|checked|disabled|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: label, sublabel, checked, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute > JSXIdentifier[name!=/^(?:bars|height|active|color|levels|key|ref|className|style|children)$/]",
        "message": "<Waveform> doesn't accept that prop. Declared props: bars, height, active, color, levels."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
