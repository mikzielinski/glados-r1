# --- Brain ---
# slm    = 100% local Ollama on your Mac — no cloud LLM (recommended)
# hybrid = local SLM for chat + Cursor cloud for code/net/GitHub/UiPath (recommended)
# cursor = always Cursor SDK (cloud)
# echo   = canned replies for audio pipeline tests
BRAIN_MODE=hybrid

# --- Local SLM (Ollama — runs on THIS Mac, 127.0.0.1 only, no internet) ---
# Chat turns use this — fast, no cloud agent, fewer WebSocket drops on R1.
# Setup: ../scripts/setup-ollama.sh
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
SLM_TIMEOUT_MS=45000
# Max wait for one cloud (Cursor) turn — GitHub/UiPath/repo work can take several minutes.
CLOUD_TURN_TIMEOUT_MS=600000
# Spoken progress update while a cloud agent run is in flight (ms).
CLOUD_PROGRESS_INTERVAL_MS=45000
SLM_MAX_TOKENS=120
SLM_HISTORY_TURNS=4

# --- Cursor SDK (code + internet tasks) ---
# User API key from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_xxx
# Model for the coding/chat agent. composer-2.5 is a sensible default.
CURSOR_MODEL=composer-2.5
# Absolute path to the repo the agent should work in (local runtime cwd).
REPO_PATH=/Users/you/code/your-project

# --- Server ---
# Bind host. Use your Tailscale IP (or 0.0.0.0) so the R1 can reach it.
HOST=0.0.0.0
PORT=8787

# --- Speech-to-text (Whisper, local) ---
# Path to a whisper.cpp CLI binary (whisper-cli / main) and a ggml model.
# For Polish use a multilingual model (ggml-small.bin or larger), NOT *.en.bin.
# Run: ../scripts/setup-whisper-pl.sh
WHISPER_BIN=whisper-cli
WHISPER_MODEL=/opt/whisper/models/ggml-small.bin
# Language hint: pl, en, or auto
WHISPER_LANG=pl
# Polish context prompt improves recognition accuracy
WHISPER_PROMPT=Użytkownik mówi po polsku. Przykład: Dzień dobry, napraw błąd w kodzie.
WHISPER_THREADS=4
WHISPER_NO_SPEECH_THOLD=0.45

# --- Text-to-speech (GLaDOS voice) ---
# TTS_MODE: auto | fish | glados-net | piper | say | mock
# auto: Fish Audio if FISH_API_KEY set; else glados.c-net.org for English,
#       macOS Zosia for Polish; else piper/say.
TTS_MODE=auto
# TTS routing per skin:
#   GLaDOS + FISH_API_KEY → Fish PL clone (6fc91ffb…)
#   HAL / TARS + Polish → Piper pl_PL-darkman (male) + voice FX (hal/tars presets)
#   GLaDOS + Polish → Piper pl_PL-gosia (female) + portal FX, or Fish PL clone
#   HAL / TARS + English → Fish character voice
TTS_GLADOS_FX=true
TTS_GLADOS_FX_PRESET=portal
# Fish Audio GLaDOS — https://fish.audio/app/developers (API credit required)
FISH_API_KEY=
FISH_VOICE_ID=6fc91ffb3fe9444bb210f6d29f55d56d
FISH_VOICE_ID_HAL=06d2f87a335342f098ffd6b127a682fe
FISH_VOICE_ID_TARS=6a57e35f5c8244dbb5d012a3c434ec16
FISH_MODEL=s2-pro
# Free Portal GLaDOS voice (English text only, max 256 chars per request):
GLADOS_NET_URL=https://glados.c-net.org/generate
# macOS Polish voice when Fish key missing and reply is in Polish:
SAY_VOICE_PL=Zosia
# English GLaDOS (Portal voice) — English text only
PIPER_MODEL=/Users/you/glados-r1/models/piper/en_US-glados.onnx
PIPER_CONFIG=/Users/you/glados-r1/models/piper/en_US-glados.onnx.json
# Polish voice — run: ../scripts/setup-piper-pl.sh
PIPER_MODEL_PL=/Users/you/glados-r1/models/piper/pl_PL-gosia-medium.onnx
PIPER_CONFIG_PL=/Users/you/glados-r1/models/piper/pl_PL-gosia-medium.onnx.json
# HAL / TARS use male voice (auto-detected if darkman sits next to gosia):
# PIPER_MODEL_PL_MALE=/Users/you/glados-r1/models/piper/pl_PL-darkman-medium.onnx
# Optional: Fish Audio GLaDOS speaks Polish WITH Portal voice (https://fish.audio/app/api-keys)
# FISH_API_KEY=
# Legacy dev fallback (prefer TTS_MODE=say instead):
TTS_FALLBACK=

# --- Audio formats on the wire ---
# R1 microphone capture (what the Android app streams up).
INPUT_SAMPLE_RATE=16000

# --- Integrations wizard (GitHub + UiPath OAuth) ---
# Credentials stored in INTEGRATIONS_FILE (not committed). Open wizard at SETUP_BASE_URL/setup
INTEGRATIONS_FILE=.integrations.json
# Public URL for OAuth callbacks (must match GitHub/UiPath redirect URIs)
SETUP_BASE_URL=http://127.0.0.1:8787
# Optional: pre-fill GitHub OAuth App (or enter in wizard)
SETUP_GITHUB_CLIENT_ID=
SETUP_GITHUB_CLIENT_SECRET=

# --- Skills (n8n) ---
# JSON registry of skills exposed to the agent as callable tools. Reloaded
# automatically when the file changes (no restart needed).
SKILLS_FILE=skills/skills.json
# Base URL for n8n; skills can use a bare path resolved against this, or a full URL.
N8N_BASE_URL=http://glados-mac:5678
# Optional auth header sent with every skill webhook, as "Header-Name: value".
# e.g. for an n8n header-auth credential or a shared secret.
N8N_AUTH_HEADER=

# --- PDF standards (company norms) ---
# Drop *.pdf files here; text is injected into cloud agent prompts.
STANDARDS_DIR=/Users/you/glados-r1/standards
STANDARDS_MAX_CHARS=14000

# --- Logging ---
LOG_LEVEL=info
